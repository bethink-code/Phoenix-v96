# Phoenix v96 — env variable documentation
# DO NOT create a .env file. Secrets live in Doppler.
# Run: `doppler setup` once, then `npm run dev` which auto-injects.

# === Baseline ===
NODE_ENV=
DATABASE_URL=
SESSION_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APP_URL=
ADMIN_EMAIL=

# === Phoenix-specific ===
PAPER_TRADING_MODE=
EXCHANGE_KEY_ENCRYPTION_KEY=
ANTHROPIC_API_KEY=
BINANCE_API_BASE_URL=

# === Optional (wire later) ===
# BYBIT_API_BASE_URL=
# COINGLASS_API_KEY=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=
